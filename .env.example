# ─────────────────────────────────────────────────────────────────────────────
# Example configuration — copy to `.env` and fill in the real values.
# `.env` is ignored by Git (see .gitignore). NEVER commit the real `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Secret salt (pepper) used for the HMAC-SHA256 pseudonymisation of operators.
# It must stay CONSTANT across runs (otherwise pseudonyms change and longitudinal
# consistency is lost), and SECRET (otherwise anonymisation is reversible through
# a dictionary attack on the names).
# Generate a random value, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
ANONYMIZATION_SALT=change-me-with-a-long-random-secret

# Length (in hexadecimal characters) of the truncated operator_name pseudonym.
PSEUDONYM_LENGTH=16
