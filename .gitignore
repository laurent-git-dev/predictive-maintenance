# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets / configuration locale
.env
.env.*
!.env.example

# Données — NE JAMAIS committer de données brutes ou nominatives.
# Elles sont versionnées via DVC (fichiers .dvc seuls dans Git).
data/raw/*
data/processed/*
data/external/*
!data/**/.gitkeep
!data/**/*.dvc

# Datasets produits par couche (bronze/silver) — potentiellement volumineux,
# et le bronze peut contenir du texte libre. Versionnables via DVC au besoin.
artifacts/ingestions/**/bronze/*.csv
artifacts/ingestions/**/silver/*.csv

# Clés de pseudonymisation (mapping hash -> identité réelle) : jamais dans le repo.
*.mapping.json
mappings/

# Notebooks : sorties volumineuses
.ipynb_checkpoints/

# OS
Thumbs.db
.DS_Store
